syntax on 
"set t_Co=256

set number relativenumber
set encoding=utf-8 
set clipboard=unnamedplus
set cursorline
set viewoptions=cursor,folds,slash,unix
set timeoutlen=1000
set nocompatible
set tabstop=8 softtabstop=0 expandtab shiftwidth=4 smarttab

nnoremap j gj
vnoremap j gj
nnoremap k gk
vnoremap k gk

nnoremap <Tab>    :bnext!     <CR>
nnoremap <S-Tab>  :bprevious! <CR>
